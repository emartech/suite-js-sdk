{
  "name": "suite-js-sdk",
  "description": "",
  "main": "index.js",
  "files": [
    "api/",
    "authentication/",
    "lib/",
    "translations/",
    "config.js",
    "!*.spec.js"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "NODE_ENV=test mocha --reporter spec --ui bdd $(find . -name \"*.spec.js\" -not -path \"./node_modules/*\")",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "validate-commit-msg": "validate-commit-msg",
    "release": "semantic-release",
    "verify": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emartech/suite-js-sdk.git"
  },
  "author": "Viktor Somodi <viktor.somodi@emarsys.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emartech/suite-js-sdk/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "pre-commit": [
    "lint",
    "validate-commit-msg"
  ],
  "homepage": "https://github.com/emartech/suite-js-sdk",
  "dependencies": {
    "@emartech/escher-request": "^23.1.4",
    "@emartech/json-logger": "^9.2.3",
    "axios": "^1.15.0",
    "escher-auth": "^4.0.2",
    "escher-keypool": "^3.0.0",
    "flat": "^5.0.2",
    "lodash": "^4.18.1",
    "moment-timezone": "^0.6.0",
    "node-cache": "^5.1.2",
    "sprintf-js": "^1.1.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "eslint": "10.2.0",
    "eslint-plugin-chai-friendly": "1.1.1",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-security": "4.0.0",
    "globals": "17.4.0",
    "mocha": "11.7.5",
    "nock": "14.0.11",
    "pre-commit": "1.2.2",
    "semantic-release": "25.0.3",
    "sinon": "21.0.3",
    "sinon-chai": "4.0.1",
    "validate-commit-message": "3.2.0"
  }
}
